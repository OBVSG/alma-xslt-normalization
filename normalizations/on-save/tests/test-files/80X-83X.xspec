<?xml version="1.0" encoding="utf-8"?>
<x:description xmlns:x="http://www.jenitennison.com/xslt/xspec"
               xmlns:marc="http://www.loc.gov/MARC21/slim"
               stylesheet="../../normalize-on-save.xsl">

  <x:scenario label="80X-83X">
    <x:scenario label="830 $$w, ISIL ergänzen">
      <x:scenario label="830 $$w, ISIL vorhanden">
        <x:context>
          <datafield tag="830" ind1=" " ind2="0">
            <subfield code="w">(AT-OBV)AC12345678</subfield>
            <subfield code="v">1,1</subfield>
          </datafield>
        </x:context>
        <x:expect label="keine Änderung">
          <datafield tag="830" ind1=" " ind2="0">
            <subfield code="w">(AT-OBV)AC12345678</subfield>
            <subfield code="v">1,1</subfield>
          </datafield>
        </x:expect>
      </x:scenario>
      <x:scenario label="830 $$w, ISIL fehlt">
        <x:context>
          <datafield tag="830" ind1=" " ind2="0">
            <subfield code="w">AC12345678</subfield>
            <subfield code="v">1,1</subfield>
          </datafield>
        </x:context>
        <x:expect label="ISIL-Präfix ergänzt">
          <datafield tag="830" ind1=" " ind2="0">
            <subfield code="w">(AT-OBV)AC12345678</subfield>
            <subfield code="v">1,1</subfield>
          </datafield>
        </x:expect>
      </x:scenario>
    </x:scenario>
  </x:scenario>
</x:description>
