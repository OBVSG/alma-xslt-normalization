<?xml version="1.0" encoding="utf-8"?>
<x:description xmlns:x="http://www.jenitennison.com/xslt/xspec" xmlns:marc="http://www.loc.gov/MARC21/slim" stylesheet="../../normalize-on-save.xsl">
  <x:scenario label="20X-24X">
    <x:scenario label="Feld 240">
      <x:scenario label="Indikatoren setzen">
        <x:context>
          <datafield tag="240" ind1="X" ind2="X">
            <subfield code="a">&lt;&lt;La&gt;&gt; vie quotidienne en Grèce au siècle de Périclès</subfield>
            <subfield code="l">dt.</subfield>
          </datafield>
        </x:context>
        <x:expect label="Indikatoren fix auf '10' gesetzt">
          <datafield tag="240" ind1="1" ind2="0">
            <subfield code="a">&lt;&lt;La&gt;&gt; vie quotidienne en Grèce au siècle de Périclès</subfield>
            <subfield code="l">dt.</subfield>
          </datafield>
        </x:expect>
      </x:scenario>
      <x:scenario label="Subfeld F mit Formaltitel">
        <x:context>
          <datafield tag="240" ind1="1" ind2="0">
            <subfield code="F">Romane</subfield>
          </datafield>
        </x:context>
        <x:expect label="Subfeld F in Subfeld a umgewandelt">
          <datafield tag="240" ind1="1" ind2="0">
            <subfield code="a">Romane</subfield>
          </datafield>
        </x:expect>
      </x:scenario>
    </x:scenario>
    <x:scenario label="Feld 242">
      <x:scenario label="242 ohne Subfeld y">
        <x:context>
          <datafield tag="242" ind1="0" ind2="0">
            <subfield code="a">Reguläre Dirichlet-Voronoi-Zerlegungen der zweiten triklinen Gruppe</subfield>
          </datafield>
        </x:context>
        <x:expect label="$$yger hinzugefügt">
          <datafield tag="242" ind1="0" ind2="0">
            <subfield code="a">Reguläre Dirichlet-Voronoi-Zerlegungen der zweiten triklinen Gruppe</subfield>
            <subfield code="y">ger</subfield>
          </datafield>
        </x:expect>
      </x:scenario>
      <x:scenario label="242 mit Subfeld y">
        <x:context>
          <datafield tag="242" ind1="0" ind2="0">
            <subfield code="a">Reguläre Dirichlet-Voronoi-Zerlegungen der zweiten triklinen Gruppe</subfield>
            <subfield code="y">ger</subfield>
          </datafield>
        </x:context>
        <x:expect label="keine Änderung">
          <datafield tag="242" ind1="0" ind2="0">
            <subfield code="a">Reguläre Dirichlet-Voronoi-Zerlegungen der zweiten triklinen Gruppe</subfield>
            <subfield code="y">ger</subfield>
          </datafield>
        </x:expect>
      </x:scenario>
    </x:scenario>
  </x:scenario>

</x:description>
