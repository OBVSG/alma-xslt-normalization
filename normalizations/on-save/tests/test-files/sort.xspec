            <subfield code="a">Notenbuch seinem Sohne Wolfgang Amadeus zu dessen siebenten Namenstag geschenkt</subfield>
            <subfield code="k">Auswahl</subfield>
          </datafield>
        </x:context>
        <x:expect label="richtig sortiert">
          <datafield tag="130" ind1=" " ind2=" ">
            <subfield code="a">Notenbuch seinem Sohne Wolfgang Amadeus zu dessen siebenten Namenstag geschenkt</subfield>
            <subfield code="0">(DE-588)111111111</subfield>
            <subfield code="k">Auswahl</subfield>
            <subfield code="o">arrangiert</subfield>
          </datafield>
        </x:expect>
      </x:scenario>
    </x:scenario>
