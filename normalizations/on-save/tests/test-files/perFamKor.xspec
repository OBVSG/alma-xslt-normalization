<?xml version="1.0" encoding="utf-8"?>
<x:description xmlns:x="http://www.jenitennison.com/xslt/xspec" stylesheet="../../normalize-on-save.xsl">

  <x:scenario label="personInd1">
    <x:scenario label="'Familie', 'Clan', 'Dynastie' oder 'Dynasty' in SFc">
      <x:context select="datafield/@ind1">
        <datafield tag="700" ind1="1" ind2=" ">
          <subfield code="a">Maier</subfield>
          <subfield code="c">Familie : 1701 -</subfield>
        </datafield>
        <datafield tag="700" ind1="1" ind2=" ">
          <subfield code="a">Maier</subfield>
          <subfield code="c">Clan, Schuster</subfield>
        </datafield>
        <datafield tag="700" ind1="1" ind2=" ">
          <subfield code="a">Maier</subfield>
          <subfield code="c">Dynastie</subfield>
        </datafield>
        <datafield tag="700" ind1="1" ind2=" ">
          <subfield code="a">Maier</subfield>
          <subfield code="c">Dynasty</subfield>
        </datafield>
      </x:context>
      <x:call template="personInd1" />
      <x:expect label="ind1 = '3'" select="//@ind1">
        <dummy ind1="3" />
        <dummy ind1="3" />
        <dummy ind1="3" />
        <dummy ind1="3" />
      </x:expect>
      <!-- <x:expect label="ind1 auf 3 gesetzt" -->
      <!--           select="('3', '3', '3', '3', '1')" /> -->
    </x:scenario>
    <x:scenario label="Beistrich in SFa">
      <x:context select="datafield/@ind1">
        <datafield tag="700" ind1="1" ind2=" ">
          <subfield code="a">Kirk, James T.</subfield>
        </datafield>
        <datafield tag="700" ind1="3" ind2=" ">
          <subfield code="a">Picard, Jean-Luc</subfield>
        </datafield>
      </x:context>
      <x:call template="personInd1" />
      <x:expect label="ind1 = '1'" select="//@ind1">
        <dummy ind1="1" />
        <dummy ind1="1" />
      </x:expect>
    </x:scenario>
    <x:scenario label="Persönliche Namen / Vornamen">
      <x:context select="datafield/@tag">
        <datafield tag="700" ind1=" " ind2=" ">
          <subfield code="a">Spock</subfield>
        </datafield>
        <datafield tag="700" ind1="1" ind2=" ">
          <subfield code="a">Seven of Nine</subfield>
        </datafield>
        <datafield tag="700" ind1="0" ind2=" ">
          <subfield code="a">Q</subfield>
          <subfield code="c">Entität, allmächtige</subfield>
        </datafield>
      </x:context>
      <x:call template="personInd1" />
      <x:expect label="ind1 = '0'" select="//@ind1">
        <dummy ind1="0" />
        <dummy ind1="0" />
        <dummy ind1="0" />
      </x:expect>
    </x:scenario>
  </x:scenario>
  <x:scenario label="addDefaultRelator">
    <x:scenario label="Feld 100, SF4 vorhanden">
      <x:context>
        <datafield tag="100" ind1="1" ind2=" ">
          <subfield code="a">Muster, Max</subfield>
          <subfield code="4">cmp</subfield>
        </datafield>
      </x:context>
      <x:call template="addDefaultRelator" />
      <x:expect label="kein Output" />
    </x:scenario>
    <x:scenario label="Feld 110, SF4 vorhanden">
      <x:context>
        <datafield tag="110" ind1="2" ind2=" ">
          <subfield code="a">ACME Corp.</subfield>
          <subfield code="4">cmp</subfield>
        </datafield>
      </x:context>
      <x:call template="addDefaultRelator" />
      <x:expect label="kein Output" />
    </x:scenario>
    <x:scenario label="Feld 100, SF4 vorhanden aber leer, LDR/06=a">
      <x:context>
        <datafield tag="100" ind1="1" ind2=" ">
          <subfield code="a">Muster, Max</subfield>
          <subfield code="4"></subfield>
        </datafield>
      </x:context>
      <x:call template="addDefaultRelator">
        <x:param name="meta" tunnel="yes" select="map{'ldr06': 'a'}" />
      </x:call>
      <x:expect label="SF4 aut">
        <subfield code="4">aut</subfield>
      </x:expect>
    </x:scenario>
    <x:scenario label="Feld 110, kein SF4, LDR/06=c">
      <x:context>
        <datafield tag="110" ind1="2" ind2=" ">
          <subfield code="a">ACME Corp.</subfield>
        </datafield>
      </x:context>
      <x:call template="addDefaultRelator">
        <x:param name="meta" tunnel="yes" select="map{'ldr06': 'c'}" />
      </x:call>
      <x:expect label="SF4 cmp">
        <subfield code="4">cmp</subfield>
      </x:expect>
    </x:scenario>
    <x:scenario label="Feld 111, kein SF4, LDR/06=r">
      <x:context>
        <datafield tag="111" ind1="2" ind2=" ">
          <subfield code="a">Ägidi-Kirtag</subfield>
          <subfield code="b">St. Bartholomä</subfield>
          <subfield code="d">2000</subfield>
        </datafield>
      </x:context>
      <x:call template="addDefaultRelator">
        <x:param name="meta" tunnel="yes" select="map{'ldr06': 'r'}" />
      </x:call>
      <x:expect label="SF4cre">
        <subfield code="4">cre</subfield>
      </x:expect>
    </x:scenario>

    <x:scenario label="700 mit SFt">
      <x:context>
        <datafield tag="700" ind1="1" ind2="2">
          <subfield code="a">Toussaint, Jean-Philippe</subfield>
          <subfield code="d">1957-</subfield>
          <subfield code="t">&lt;&lt;La&gt;&gt; salle de bain</subfield>
          <subfield code="0">(DE-588)4632142-1</subfield>
        </datafield>
      </x:context>
      <x:call template="addDefaultRelator" />
      <x:expect label="kein Output" />
    </x:scenario>
    <x:scenario label="710 mit leerem SF4">
      <x:context>
        <datafield tag="710" ind1="2" ind2=" ">
          <subfield code="a">Eisschützenverein Oberdorf</subfield>
          <subfield code="4"></subfield>
        </datafield>
      </x:context>
      <x:call template="addDefaultRelator" />
      <x:expect label="SF4 ctb">
        <subfield code="4">ctb</subfield>
      </x:expect>
    </x:scenario>
    <x:scenario label="711 ohne SF4">
      <x:context>
        <datafield tag="711" ind1="2" ind2=" ">
          <subfield code="a">Colloquium on Logic and Ontology</subfield>
          <subfield code="d">1973</subfield>
          <subfield code="c">Salzburg</subfield>
          <subfield code="0">(DE-588)5502228-5</subfield>
        </datafield>
      </x:context>
      <x:call template="addDefaultRelator" />
      <x:expect label="SF4 ctb">
        <subfield code="4">ctb</subfield>
      </x:expect>
    </x:scenario>
  </x:scenario>

</x:description>
