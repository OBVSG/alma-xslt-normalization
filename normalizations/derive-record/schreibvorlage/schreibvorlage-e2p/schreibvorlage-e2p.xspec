      <datafield tag="776" ind1="0" ind2="8">
        <subfield code="i">Erscheint auch als</subfield>
        <subfield code="n">Online-Ausgabe</subfield>
        <subfield code="z">9781234567890</subfield>
      </datafield>
    </x:expect>
  </x:scenario>

  <x:scenario label="300">
