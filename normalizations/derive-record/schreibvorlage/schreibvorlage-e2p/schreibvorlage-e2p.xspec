  <x:scenario label="Print-ISBN nach 020 übertragen">
    <x:scenario label="mehrere Subfelder z">
      <x:context>
        <datafield tag="776" ind1="0" ind2="8">
          <subfield code="i">Erscheint auch als</subfield>
          <subfield code="n">Steintafel-Ausgabe</subfield>
          <subfield code="z">9781234567890</subfield>
        </datafield>
        <datafield tag="776" ind1="0" ind2="8">
          <subfield code="i">Erscheint auch als</subfield>
          <subfield code="n">Druck-Ausgabe</subfield>
          <subfield code="z">9781138211865</subfield>
          <subfield code="z">9781138211889</subfield>
        </datafield>
        <datafield tag="776" ind1="0" ind2="8">
          <subfield code="i">Erscheint auch als</subfield>
          <subfield code="n">Druck-Ausgabe</subfield>
          <subfield code="9">Ich habe kein Subfeld z</subfield>
        </datafield>
      </x:context>
      <x:expect label="je eine 020 pro SFz">
        <datafield tag="776" ind1="0" ind2="8">
          <subfield code="i">Erscheint auch als</subfield>
          <subfield code="n">Steintafel-Ausgabe</subfield>
          <subfield code="z">9781234567890</subfield>
        </datafield>
        <datafield tag="020" ind1=" " ind2=" ">
          <subfield code="a">9781138211865</subfield>
        </datafield>
        <datafield tag="020" ind1=" " ind2=" ">
          <subfield code="a">9781138211889</subfield>
        </datafield>
      </x:expect>
    </x:scenario>
  </x:scenario>

